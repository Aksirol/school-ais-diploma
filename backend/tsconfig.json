{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "rootDir": "./src",                                  /* ЗМІНЕНО НА ./src */
    "outDir": "./dist",                                  /* ЗМІНЕНО НА ./dist */
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/**/*"],                               /* ДОДАНО */
  "exclude": ["node_modules", "dist"]                    /* ДОДАНО */
}